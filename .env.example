# ─── Expo / React Native app (safe public config only) ───────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER put secrets (OpenRouter key, service role key) here.

# Supabase project URL (public, safe to expose)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon key (public, safe to expose — Row Level Security must be correct)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Formspree public endpoint for notifications sent directly from the app.
# Default fallback is already baked into the service, so this is optional.
EXPO_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xxx


# ─── Supabase Edge Function secrets ──────────────────────────────────────────
# Configure these with the Supabase CLI after deploying the function.
# These are NEVER put in this file or any Expo env file.
#
#   supabase secrets set OPENROUTER_API_KEY=<your_key>
#   supabase secrets set OPENROUTER_MODEL=openai/gpt-3.5-turbo
#   supabase secrets set FORMSPREE_ENDPOINT=https://formspree.io/f/xxx
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are automatically injected into
# every Supabase Edge Function — you do NOT need to set them manually.
